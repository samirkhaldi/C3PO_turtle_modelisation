:WP2 rdf:type :WorkPackage .
:WP2 :aboutProject :LUMEN .
:WP2 :gotName "WP2" . 
:WP2 :RP :P1 .

:WP3 rdf:type :WorkPackage .
:WP3 :aboutProject :LUMEN .
:WP3 :gotName "WP3" . 
:WP3 :RP :P1 .

:WP4 rdf:type :WorkPackage .
:WP4 :aboutProject :LUMEN .
:WP4 :gotName "WP4" . 
:WP4 :RP :P1 .

:Task a rdfs:Class . 
:Task :includeIn :EuropeanProject .
:Task :gotName xsd:string .
:Task :personMonthSpent xsd:integer .

:Task1 rdf:type :Task .
:Task1 :includeIn :LUMEN .
:Task1 :gotName "Task 1.0" . 
:Task1 :relatedWP :WP4 .
:Task1 :RP :P1 .




