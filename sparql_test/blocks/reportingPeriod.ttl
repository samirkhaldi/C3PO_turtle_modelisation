@prefix : <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:ReportingPeriod a rdfs:Class . 

:EuropeanProject a rdfs:Class .

:hasReportingPeriod a rdf:Property .
:startDate a rdf:Property .
:endDate a rdf:Property .
:duration a rdf:Property .

:LUMEN a :EuropeanProject ;
    :startDate "2025-01-01"^^xsd:date ;
    :endDate "2028-12-31"^^xsd:date ;
    :duration "P48M"^^xsd:duration ;
    :hasReportingPeriod :P1, :RP1, :RP2, :RP3 ;
    :id 1 .

#reporting period enties

:P1 a :ReportingPeriod ;
    :aboutProject :LUMEN ;
    :gotName "P1" ;
    :duration "P1M"^^xsd:duration ;
    :startDate "2025-01-01"^^xsd:date ;
    :endDate "2025-01-31"^^xsd:date .

:RP1 a :ReportingPeriod ;
    :aboutProject :LUMEN ;
    :gotName "RP1" ;
    :duration "P12M"^^xsd:duration ;
    :startDate "2025-01-01"^^xsd:date ;
    :endDate "2025-12-31"^^xsd:date .

:RP2 a :ReportingPeriod ;
    :aboutProject :LUMEN ;
    :gotName "RP2" ;
    :duration "P12M"^^xsd:duration ;
    :startDate "2026-01-01"^^xsd:date ;
    :endDate "2026-12-31"^^xsd:date .

:RP3 a :ReportingPeriod ;
    :aboutProject :LUMEN ;
    :gotName "RP3" ;
    :duration "P24M"^^xsd:duration ;
    :startDate "2027-01-01"^^xsd:date ;
    :endDate "2028-12-31"^^xsd:date .
