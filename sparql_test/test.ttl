@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://www.turtle_tutorial.com/>.

:EuropeanProject a rdfs:Class .

:TravelInformation a rdfs:Class .
:TravelInformation :travelEventName xsd:string .
:TravelInformation :aboutProject :EuropeanProject .
:TravelInformation :gotPurpose xsd:string . 
:TravelInformation :gotPeriod :ReportingPeriod .
:TravelInformation :startDate xsd:date .
:TravelInformation :endDate xsd:date .
:TravelInformation :destination xsd:string .
:TravelInformation :cost xsd:integer .

:TravelInvoice rdf:subClassOf :TravelInformation .
:TravelInvoice :category xsd:string .
:TravelInvoice :aboutProject :EuropeanProject .
:TravelInvoice :duringPeriod :ReportingPeriod .
:TravelInvoice :beneficiary :Employee .
:TravelInvoice :hasDate xsd:date .
:TravelInvoice :amount xsd:integer .

:Travel_1 rdf:type :TravelInformation .
:Travel_1 :travelEventName "LUMEN_Meet1" .
:Travel_1 :gotPeriod :RP2 .
:Travel_1 :aboutProject :LUMEN . 
:Travel_1 :destination "Milan" .
:Travel_1 :cost 1240 .
:Travel_1 :gotPurpose "SHOPPING" .
:Travel_1 :startDate "2025-09-23" .
:Travel_1 :endDate "2025-09-24" .

:Travel_2 rdf:type :TravelInformation .
:Travel_2 :travelEventName "LUMEN_Meet3" .
:Travel_2 :aboutProject :LUMEN . 
:Travel_2 :cost 5400 .
:Travel_2 :gotPeriod :RP3 .

:Fees_1  rdf:type :TravelInvoice .
:Fees_1 :category "uber receipt" .
:Fees_1 :aboutProject :LUMEN .
:Fees_1 :duringPeriod :RP1 .
:Fees_1 :duringTravel :Travel_1 .
:Fees_1 :hasDate "2025-09-23" .
:Fees_1 :beneficiary :Yann .
:Fees_1 :amount 45 .

:Fees_2 rdf:type :TravelInvoice .
:Fees_2 :category "restaurant receipt" .
:Fees_2 :aboutProject :LUMEN .
:Fees_2 :duringPeriod :RP1 .
:Fees_1 :duringTravel :Travel_1 .
:Fees_2 :hasDate "2025-09-23" .
:Fees_2 :beneficiary :Yann .
:Fees_2 :amount 23 .

:WorkPackage a rdfs:Class . 
:WorkPackage :about :EuropeanProject .
:WorkPackage :gotName xsd:string .
:WorkPackage :personMonthSpent xsd:integer .

:ReportingPeriod a rdfs:Class . 
:ReportingPeriod :about :EuropeanProject .
:ReportingPeriod :totalPersonnalCost xsd:integer . 
:ReportingPeriod :gotName :xsd:string .
:ReportingPeriod :month xsd:string .

:Employee a rdfs:Class .
:Employee :gotAnnualProductiveHours xsd:integer .
:Employee :gotSalaryGross xsd:integer .
:Employee :gotPatronalContribution xsd:integer .
:Employee :workOn :EuropeanProject .
:Employee :hoursWorkedOnLumen xsd:integer .
:Employee :WorkedOnLumenDuring :ReportingPeriod .
:Employee :gotHourlyRate xsd:integer .
:Employee :Name xsd:string .

:GreatCompany a rdfs:Class .
:GreatCompany :have :Employee .

:Yann rdf:type :Employee .
:Yann :workAt :GreatCompany .
:Yann :workOn :LUMEN .
:Yann :gotSalaryGross 2000 .
:Yann :gotAnnualProductiveHours 1720 .
:Yann :gotPatronalContribution 200 .
:Yann :WorkedOnLumenDuring :P1 .
:Yann :hoursWorkedOnLumen 32 .
:Yann :Name "Yann" .

:50cent rdf:type :Employee .
:50cent :workOn :LUMEN .
:50cent :gotSalaryGross 5000 .
:50cent :gotPatronalContribution 500 .
:50cent :gotAnnualProductiveHours 1720 .
:50cent :workAt :GreatCompany .
:50cent :WorkedOnLumenDuring :RP3 .
:50cent :hoursWorkedOnLumen: 50 .
:50cent :Name "50cent" .

:Zidane rdf:type :Employee .
:Zidane :workOn :LUMEN .
:Zidane :gotSalaryGross 8000 .
:Zidane :workAt :GreatCompany .
:Zidane :gotPatronalContribution 500 .
:Zidane :gotAnnualProductiveHours 1720 .
:Zidane :hoursWorkedDOnLumenDuring :P1 .
:Zidane :hoursWorkedOnLumen: 10 .
:Zidane :Name "Zidane" .

:LUMEN rdf:type :EuropeanProject . 
:LUMEN :id 1 .

:P1 rdf:type :ReportingPeriod .
:P1 :aboutProject :LUMEN .
:P1 :gotName "P1" .
:P1 :month "January" .

:RP1 rdf:type :EuropeanProject .
:RP1 :aboutProject :LUMEN .
:RP1 :gotName "RP1" .
:RP1 :monthDuration 2 .
:RP1 :totalPersonnalCost 35000 .


:RP2 rdf:type :ReportingPeriod .
:RP2 :aboutProject :LUMEN .
:RP2 :gotName "RP2" .
:RP2 :monthDuration 2 .

:RP3 rdf:type :ReportingPeriod .
:RP3 :gotName "RP3" .
:RP3 :aboutProject :LUMEN .
:RP3 :totalPersonnalCost 23000 .
:RP3 :monthDuration 4 .

:WP2 rdf:type :WorkPackage .
:WP2 :about :LUMEN .
:WP2 :gotName "WP2" . 
:WP2 :personMonthSpent 6 .
:WP2 :RP :P1 .

:WP3 rdf:type :WorkPackage .
:WP3 :about :LUMEN .
:WP3 :gotName "WP3" . 
:WP3 :personMonthSpent 10 .
:WP3 :RP :P1 .

:WP4 rdf:type :WorkPackage .
:WP4 :about :LUMEN .
:WP4 :gotName "WP4" . 
:WP4 :personMonthSpent 15 .
:WP4 :RP :P1 .

:Tasks a rdfs:Class . 
:Tasks :includeIn :EuropeanProject .
:Tasks :gotName xsd:string .
:Tasks :personMonthSpent xsd:integer .

:Task1 rdf:type :WorkPackage .
:Task1 :includeIn :LUMEN .
:Task1 :gotName "Task 1.0" . 
:Task1 :personMonthSpent 6 .
:Task1 :RP :RP1 .

:Travel_1 rdf:type :TravelInformation .
:Travel_1 :travelEventName "LUMEN_Meet1" .
:Travel_1 :gotPeriod :RP2 .
:Travel_1 :aboutProject :LUMEN . 
:Travel_1 :destination "Milan" .
:Travel_1 :cost 1240 .
:Travel_1 :gotPurpose "SHOPPING" .
:Travel_1 :startDate "2025-09-23" .
:Travel_1 :endDate "2025-09-24" .

:Travel_2 rdf:type :TravelInformation .
:Travel_2 :travelEventName "LUMEN_Meet3" .
:Travel_2 :aboutProject :LUMEN . 
:Travel_2 :cost 5400 .
:Travel_2 :gotPeriod :RP3 .


