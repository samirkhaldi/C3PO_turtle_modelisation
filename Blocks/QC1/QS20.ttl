@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://www.turtle_tutorial.com/>.

:Employee a rdfs:Class .
:Employee :gotAnnualProductiveHours xsd:integer .

:Yann rdf:type :Employee .
:Yann :gotAnnualProductiveHours 1720 .

SELECT ?annualproductivehours
WHERE { 
  ?yann :gotAnnualProductiveHours ?annualproductivehours .  
}