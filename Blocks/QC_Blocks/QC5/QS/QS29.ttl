@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://www.turtle_tutorial.com/>.

:EuropeanProject a rdfs:Class .

:LUMEN rdf:type :EuropeanProject . 

:ReportingPeriod a rdfs:Class . 
:ReportingPeriod :aboutProject :EuropeanProject .
:ReportingPeriod :gotName :xsd:string .

:RP1 rdf:type :EuropeanProject .
:RP1 :aboutProject :LUMEN .
:RP1 :gotName "RP1" .

:RP2 rdf:type :EuropeanProject .
:RP2 :aboutProject :LUMEN .
:RP2 :gotName "RP2" .

:TravelInformation a rdfs:Class .
:TravelInformation :travelEventName xsd:string .
:TravelInformation :aboutProject :EuropeanProject .
:TravelInformation :gotPurpose xsd:string . 
:TravelInformation :gotPeriod :ReportingPeriod .


:Travel_1 rdf:type :TravelInformation .
:Travel_1 :travelEventName "LUMEN_Meet1" .
:Travel_1 :gotPeriod :RP1 .
:Travel_1 :aboutProject :LUMEN . 

:Travel_2 rdf:type :TravelInformation .
:Travel_2 :travelEventName "LUMEN_Meet2" .
:Travel_2 :aboutProject :LUMEN . 

