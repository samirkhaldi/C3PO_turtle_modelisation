@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://www.turtle_tutorial.com/>.

:Employee a rdfs:Class .
:Employee :gotHourlyRate xsd:integer .

:Yann rdf:type :Employee .
:Yann :gotHourlyRate: 100 .
:Yann :Name "Yann" .

:50cent rdf:type :Employee .
:50cent :gotHourlyRate: 1000 .
:50cent :Name "50cent" .

:Zidane rdf:type :Employee .
:Zidane :gotHourlyRate: 10000 .
:Zidane :Name "Zidane" .


