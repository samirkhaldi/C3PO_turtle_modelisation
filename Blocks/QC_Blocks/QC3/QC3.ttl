@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://www.turtle_tutorial.com/>.

:EuropeanProject a rdfs:Class .

:LUMEN rdf:type :EuropeanProject . 

:Employee a rdfs:Class .
:Employee :workOn :EuropeanProject .

:Yann rdf:type :Employee .
:Yann :workOn :LUMEN .
:Yann :workDuring :RP3 .

:ReportingPeriod a rdfs:Class . 
:ReportingPeriod :about :EuropeanProject .
:ReportingPeriod :gotName :xsd:string .

:RP3 rdf:type :ReportingPeriod .
:RP3 :about :LUMEN .
:RP3 :gotName "RP3" .

#  select ?worker
# where {
# ?worker :workDuring ?RP3 .
# }