@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://www.turtle_tutorial.com/>.

:EuropeanProject a rdfs:Class .

:LUMEN rdf:type :EuropeanProject . 

:ReportingPeriod a rdfs:Class . 
:ReportingPeriod :about :EuropeanProject .
:ReportingPeriod :gotName :xsd:string .

:RP1 rdf:type :ReportingPeriod .
:RP1 :about :LUMEN .
:RP1 :gotName "RP1" .

:RP2 rdf:type :ReportingPeriod .
:RP2 :about :LUMEN .
:RP2 :gotName "RP2" .

# select ?rplist
# where {
# ?ReportingPeriod :about ?LUMEN .
# ?ReportingPeriod :gotName ?rplist .
# }