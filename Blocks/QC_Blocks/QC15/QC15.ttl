@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://www.turtle_tutorial.com/>.

:EuropeanProject a rdfs:Class .

:LUMEN rdf:type :EuropeanProject . 

:Employee a rdfs:Class .
:Employee :workOn :EuropeanProject .
:Employee :hoursWorkedOnLumen: xsd:integer .

:Yann rdf:type :Employee .
:Yann :workOn :LUMEN .
:Yann :hoursWorkedOnLumen: 32 .

:Tasks a rdfs:Class . 
:Tasks :about :EuropeanProject .
:Tasks :gotName xsd:string .
:Tasks :personMonthSpent xsd:integer .


:Task1 rdf:type :Tasks .
:Task1 :about :LUMEN .
:Task1 :gotName "Task 1.2" . 
:Task1 :personMonthSpent 6 .
:Task1 :RP :RP1 .

:ReportingPeriod a rdfs:Class . 
:ReportingPeriod :about :EuropeanProject .
:ReportingPeriod :gotName :xsd:string .

:RP1 rdf:type :EuropeanProject .
:RP1 :about :LUMEN .
:RP1 :gotName "RP1" .



