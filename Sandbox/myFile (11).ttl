@prefix : <https://www.turtle_tutorial.com/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

:Reporting a owl:Class ;
:hasRP :RP;
:hasCRP :CRP;
:hasIR :IR
.

:RP a :Reporting ;
:hasStartDate: xsd:date;
:hasEndDate: xsd:date;
:hasNumber: xsd:integer;
:reportAbout :EuropeanProject
.

:RP1 a owl:NameIndividual,:RP ;
:hasStartDate "2020-03-11" ;
:hasEndDate "2022-03-11" ;
:reportAbout :LUMEN
.

:RP2 a owl:NameIndividual,:RP ;
:hasStartDate "2022-03-11" ;
:hasEndDate "2024-03-11" ;
:reportAbout :LUMEN
.


:CRP a :Reporting ;
:hasStartDate: xsd:date;
:hasEndDate: xsd:date;
:hasNumber: xsd:integer;
:reportAbout :EuropeanProject
.

:IR a :Reporting ;
:hasStartDate: xsd:date;
:hasEndDate: xsd:date;
:hasNumber: xsd:integer;
:reportAbout :EuropeanProject
.

:WorkPackage a owl:Class ;
:hasName: xsd:string;
:hasStartDate: xsd:date;
:hasEndDate: xsd:date;
:hasId: xsd:integer ;
:workPackageAbout: :EuropeanProject
.

:WP1 a owl:NameIndividual, :WorkPackage ;
:hasStartDate "2022-03-15" ;
:hasEndDate "2022-03-28" ;
:hasName:"WP1 : Management, coordination and synchronisation";
:hasId: 1 ;
:workPackageAbout: :LUMEN
.

:WP2 a owl:NameIndividual, :WorkPackage ;
:hasStartDate "2022-03-29" ;
:hasEndDate "2022-04-13" ;
:hasName:"WP2 : FAIR Semantic artefacts Management platform";
:hasId: 2 ;
:workPackageAbout: :LUMEN
.


:EuropeanProject a owl:Class ; 
:hasName xsd:string;
:hasStartDate xsd:date;
:hasEndDate xsd:date;
:hasReporting :Reporting;
:containWorkPackage: :WorkPackage;
:hasEvent: :Event
.
               
:LUMEN a owl:NameIndividual, :EuropeanProject ;
:hasName "LUMEN";
:hasStartDate "2020-03-11";
:hasEndDate "2024-03-11";
:hasReporting :Reporting;
:containWorkPackage: :WorkPackage
.

:GRAPHIA a owl:NameIndividual, :EuropeanProject ;
:hasName "GRAPHIA";
:hasStartDate "2022-03-11";
:hasEndDate "2027-03-11";
:hasReporting :Reporting;
:containWorkPackage: :WorkPackage
.

:Employee a owl:Class ; 
:workOn :EuropeanProject ;
:hasFName ^^xsd:string ;
:hasLName ^^xsd:string ;
:hoursWorkedLumen ^^xsd:integer ;
:hoursWorkedGraphia ^^xsd:integer ;
:hasHourlyRate ^^xsd:integer ;
:received :Payslip;
:hasAnnualPersonnalCost ^^xsd:integer ;
:gotAnnualProductiveHours ^^xsd:decimal ;  
:gotmonthlyProductiveHours  ^^xsd:integer
.

:Employee1 a :Employee ;
:hasFName "Samir" ;
:hasLName "Khaldi" ;
:hoursWorkedLumen 12;
:worksOn :LUMEN;
:hasHourlyRate 30;
:gotAnnualProductiveHours 1720;
:received :Employee1_Payslip
.

:Employee2 a :Employee ;
:hasFName "Yann" ;
:hasLName "Le Franc" ;
:hoursWorkedGraphia 42 ;
:worksOn :GRAPHIA ;
:hasHourlyRate 100 ;
:gotAnnualProductiveHours 1720;
:received :Employee2_Payslip

.       

:Payslip a owl:Class ;
:salaryGrossAmount ^^xsd:integer ;
:employeeContributionAmount ^^xsd:integer 

.

:Employee1_Payslip a owl:NameIndividual, :Payslip ;
:PayslipTo :Employee1;
:salaryGrossAmount 1900 ;
:employeeContributionAmount 200   

.

:Employee2_Payslip a owl:NameIndividual, :Payslip ;
:PayslipTo :Employee2;
:salaryGrossAmount 5000 ;
:employeeContributionAmount 1200   

.

:Event a owl:Class ;
:hasStartDate xsd:date;
:hasEndDate xsd:date;
:hasName: ^^xsd:string ;
:localisation: ^^xsd:string ;
:about: :EuropeanProject 

.


:lumenEvent a owl:NameIndividual, :Event ;
:travelAbout :LUMEN;
:hasName: "TNC_25" ;
:localisation:"Paris" ;

.

: